<article class="bg-dark-card border border-border-subtle rounded-md p-6 transition-standard hover:border-accent hover:-translate-y-1 flex flex-col h-full">
  <!-- Title & Description -->
  <div class="mb-4">
    <h3 class="text-lg font-semibold text-text-primary tracking-tight mb-2">
      {{ project.title }}
    </h3>
    <p class="text-sm text-text-secondary leading-relaxed">
      {{ project.description }}
    </p>
  </div>

  <!-- Key Achievements (Results) -->
  <div class="mb-6 flex-grow">
    <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-2">Key Achievements</h4>
    <ul class="space-y-2 text-sm text-text-secondary">
      {% for result in project.results %}
      <li class="flex items-start gap-2">
        <span class="text-accent shrink-0 select-none" aria-hidden="true">→</span>
        <span>{{ result }}</span>
      </li>
      {% endfor %}
    </ul>
  </div>

  <!-- Tech Stack Badges -->
  <div class="mb-6">
    <div class="flex flex-wrap gap-1.5" aria-label="Technologies used">
      {% for tech in project.techStack %}
      <span class="px-2 py-0.5 text-xs font-mono rounded bg-accent-deep text-accent-light border border-accent-deep/50">
        {{ tech }}
      </span>
      {% endfor %}
    </div>
  </div>

  <!-- Project Links -->
  <div class="flex items-center gap-4 pt-4 border-t border-border-subtle mt-auto">
    {% if project.links.github %}
    <a href="{{ project.links.github }}" target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-text-muted hover:text-accent-light flex items-center gap-1.5 transition-standard group" aria-label="View {{ project.title }} source code on GitHub">
      <svg class="w-4 h-4 fill-current text-text-muted group-hover:text-accent-light transition-colors" viewBox="0 0 24 24" aria-hidden="true">
        <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.44 22 12.017 22 6.484 17.522 2 12 2z" />
      </svg>
      <span>Source Code</span>
    </a>
    {% endif %}

    {% if project.links.live %}
    <a href="{{ project.links.live }}" target="_blank" rel="noopener noreferrer" class="text-xs font-medium text-text-muted hover:text-accent-light flex items-center gap-1.5 transition-standard group" aria-label="Visit {{ project.title }} live demo">
      <svg class="w-4 h-4 fill-none stroke-current stroke-2 text-text-muted group-hover:text-accent-light transition-colors" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
      </svg>
      <span>Live Demo</span>
    </a>
    {% endif %}
  </div>
</article>
