---
layout: base.njk
title: "Blog | Brad Jeschonek"
description: "Documenting my thoughts and experiences with web performance, architecture, and software engineering in the age of AI agents."
permalink: /blog/
---

<div class="max-w-4xl mx-auto py-8">
  <!-- Header Section -->
  <header class="mb-12 text-center sm:text-left">
    <h1 class="text-4xl font-extrabold text-text-primary tracking-tight mb-4 sm:text-5xl">
      Blog
    </h1>
    <p class="text-lg text-text-secondary max-w-2xl leading-relaxed">
        Documenting my thoughts and experiences with web performance, architecture, and software engineering in the age of AI agents.
    </p>
  </header>

  <!-- Filter & Search Controls -->
  <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 pb-8 border-b border-border-subtle">
    <!-- Category Badges -->
    <div class="flex-grow">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">
        Filter by Category
      </h2>
      <div class="flex flex-wrap gap-2.5" id="category-filters" role="group" aria-label="Filter blog posts by category">
        <button
          data-filter="all"
          aria-pressed="true"
          class="active px-4 py-1.5 rounded-full text-xs font-semibold bg-accent text-white border border-transparent hover:border-accent-light transition-all duration-200 cursor-pointer"
        >
          All Posts
        </button>
        {% for category in categories %}
          <button
            data-filter="{{ category.id }}"
            aria-pressed="false"
            class="px-4 py-1.5 rounded-full text-xs font-semibold bg-dark-card text-text-muted border border-border-subtle hover:text-text-primary hover:border-accent-light transition-all duration-200 cursor-pointer"
          >
            {{ category.name }}
          </button>
        {% endfor %}
      </div>
    </div>

    <!-- Search Input -->
    <div class="w-full md:w-80">
      <label for="search-input" class="text-xs font-semibold uppercase tracking-wider text-text-muted block mb-3">
        Search Posts
      </label>
      <div class="relative">
        <input
          type="search"
          id="search-input"
          placeholder="Search title, content, or tags..."
          class="w-full bg-dark-card border border-border-subtle rounded-lg pl-4 pr-10 py-2 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-all duration-200"
        />
        <span class="absolute right-3 top-2.5 text-text-muted text-sm pointer-events-none" id="search-icon">🔍</span>
      </div>
    </div>
  </div>

  <!-- Live region for announcing search/filter results to screen readers -->
  <div id="search-announcer" class="sr-only" aria-live="polite"></div>

  <!-- Blog Cards Grid -->
  {% if collections.posts and collections.posts.length > 0 %}
    <div class="grid gap-6 md:grid-cols-2" id="blog-grid">
      {% for post in collections.posts %}
        {% include "components/blog-card.njk" %}
      {% endfor %}
    </div>

    <!-- Empty State -->
    <div id="no-posts-message" class="hidden text-center py-16 bg-dark-card border border-border-subtle rounded-lg">
      <div class="text-4xl mb-4">🔍</div>
      <h3 class="text-lg font-semibold text-text-primary mb-1">No posts found</h3>
      <p class="text-text-muted text-sm">No articles match the selected category.</p>
    </div>
  {% else %}
    <div class="text-center py-16 bg-dark-card border border-border-subtle rounded-lg">
      <div class="text-4xl mb-4">✍️</div>
      <h3 class="text-lg font-semibold text-text-primary mb-1">No posts yet</h3>
      <p class="text-text-muted text-sm">Check back later for new articles and insights!</p>
    </div>
  {% endif %}
</div>

<!-- Dynamic Client-Side Filtering & Search Script -->
<script src="/assets/js/search.js" defer></script>
