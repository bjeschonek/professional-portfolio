<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default("Brad Jeschonek | Full-Stack Software Engineer") }}</title>
    <meta name="description" content="{{ description | default("Professional portfolio and blog of Brad Jeschonek, a full-stack engineer who values simplicity and performance.") }}">
    <meta name="color-scheme" content="dark">
    
    <!-- Favicon (Lightweight SVG Laptop Emoji) -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>💻</text></svg>">
    
    <!-- Google Fonts Preconnect and Stylesheets -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'">
    <noscript>
      <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap">
    </noscript>

    <!-- CSS Stylesheet -->
    <link rel="stylesheet" href="/assets/styles/main.css">

    {% if site.analytics.websiteId %}
    <!-- Analytics (Privacy-focused, lightweight, respecting DNT/GPC) -->
    <script src="/assets/js/analytics.js" defer data-src="{{ site.analytics.src }}" data-website-id="{{ site.analytics.websiteId }}"></script>
    {% endif %}
  </head>
  <body class="flex flex-col min-h-screen bg-dark-bg text-text-primary font-sans antialiased">
    <!-- Accessibility Skip Link -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-text-primary focus:rounded-md focus:outline-none focus:ring-2 focus:ring-accent-light">
      Skip to main content
    </a>

    <!-- Header -->
    {% include "components/header.njk" %}
    
    <!-- Main Content Area -->
    <main id="main-content" class="flex-grow w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10" tabindex="-1">
      {{ content | safe }}
    </main>

    <!-- Footer -->
    {% include "components/footer.njk" %}
  </body>
</html>
